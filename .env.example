# LearnWeb (Moodle) credentials
LEARNWEB_URL=https://sso.uni-muenster.de/LearnWeb/learnweb2
LEARNWEB_USERNAME=
LEARNWEB_PASSWORD=

# Notion API
NOTION_TOKEN=

# KurseLearnWeb-DB (sync-courses Kommando)
# Testing: a44bf244cadc82669c11816719a8ec06
NOTION_COURSES_DB_ID=a44bf244cadc82669c11816719a8ec06

# Learnweb Inhalte-DB (push Kommando, Phase 2)
# Entwicklung/Testing: 322bf244cadc806cbabbf39757c3e27f
# Produktion (nach Freigabe): 321bf244cadc804b9d3dd94cb2daaad7
NOTION_LW_DB_ID=322bf244cadc806cbabbf39757c3e27f

# Semester-Label wird standardmäßig automatisch aus den NRW/Münster-Semesterzeiten
# in Europe/Berlin abgeleitet (SoSe: 01.04.–30.09., WS: 01.10.–31.03.).
# Nur für Backfills/Archivimporte explizit überschreiben:
# CURRENT_SEMESTER_OVERRIDE=WS 25/26
# Optional andere Zeitzone setzen:
# SEMESTER_TIMEZONE=Europe/Berlin

# Mapping: Moodle-Shortname → Notion-Kurs-Select-Wert (für das Kurs-Feld in Learnweb Inhalte)
# Einträge aus KurseLearnWeb: LW-ID → Kurs-Kürzel wie in Learnweb Inhalte definiert
# COURSE_MAP={"OR-2025_1": "OR", "FOF-2025_2": "FoF", "Informatik_I_-2025_2": "Inf1"}

# Only needed for export-zips command
# DOWNLOAD_DIR=/path/to/your/download/folder

# =========================================================================
# Transkriptions-Worker (Kommando `transcribe`, NUR lokal auf dem Mac)
# =========================================================================
# Meeting-Notizen-DB: hierhin werden die Transkripte als eigene Seiten
# geschrieben (verlinkt auf Learnweb-Inhalt + Kurs).
# Produktion: 30bbf244cadc800c9343d661406637b9
NOTION_MEETING_DB_ID=30bbf244cadc800c9343d661406637b9

# Whisper-Modell + Sprache (On-Device). large-v3-turbo = guter Kompromiss
# aus Qualität und Tempo auf Apple Silicon.
# WHISPER_MODEL=large-v3-turbo
# WHISPER_LANGUAGE=de

# Robustheit / Pfade (Defaults sind i. d. R. ausreichend)
# TRANSCRIBE_MAX_ATTEMPTS=3
# TRANSCRIBE_LOCK_PATH=/Users/thomasniermann/Scripts/learnweb_sync/transcribe.lock
# TRANSCRIBE_WORK_DIR=/Users/thomasniermann/Scripts/learnweb_sync/.transcribe_tmp

# Pfade zu System-Binaries überschreiben, falls nicht im PATH
# (launchd braucht oft den vollen Homebrew-Pfad /opt/homebrew/bin/...)
# YT_DLP_BIN=/opt/homebrew/bin/yt-dlp
# FFMPEG_BIN=/opt/homebrew/bin/ffmpeg
# FFPROBE_BIN=/opt/homebrew/bin/ffprobe
